[Unit]
Description=VPSMon Agent
After=network-online.target docker.service
Wants=network-online.target docker.service

[Service]
Type=simple
User=root
Group=root
ExecStart=/usr/local/bin/vpsmon-agent --config /etc/vpsmon.conf
Restart=always
RestartSec=3
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
