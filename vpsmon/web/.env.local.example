# Core mode
VPSMON_MOCK=true

# Agent server config (JSON array)
VPSMON_SERVERS=[{"id":"local","name":"Localhost","host":"127.0.0.1","port":7070,"tls":false}]

# Data store paths
VPSMON_KEYS_PATH=./keys.json
VPSMON_ANNOTATIONS_PATH=./annotations.json
VPSMON_COMMENTS_PATH=./alert_comments.json
VPSMON_MAINTENANCE_PATH=./maintenance.json
VPSMON_SILENCES_PATH=./silences.json
VPSMON_SHARES_PATH=./shares.json
VPSMON_AUDIT_PATH=./audit.json

# Audit behavior
VPSMON_AUDIT_ENABLED=true
VPSMON_AUDIT_RETENTION_DAYS=90
VPSMON_AUDIT_ANONYMIZE_IPS=false

# Webhook/auth
VPSMON_WEBHOOK_SECRET=change-me
VPSMON_EXPECTED_AGENT_VERSION=0.1.0

# Documentation-only (agent-side setting)
VPSMON_MAINTENANCE_CHECK_URL=http://127.0.0.1:9999/maintenance
